{
  "name": "kbo-live-backend-spike",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "poll": "tsx scripts/poll-live-games.ts",
    "dump": "tsx scripts/dump-kbo-response.ts",
    "collect:probable-pitchers": "tsx scripts/collect-probable-pitcher-records.ts",
    "validate:data": "tsx scripts/validate-data-quality.ts",
    "collect:source": "tsx scripts/collect-source-data.ts",
    "extract:league-records": "tsx scripts/extract-league-record-data.ts",
    "dump:players": "tsx scripts/dump-player-records-source.ts"
  },
  "dependencies": {
    "fastify": "^5.6.0",
    "pino-pretty": "^13.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
